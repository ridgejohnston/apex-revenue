# Apex Revenue Chrome Extension — .gitignore

# ── Dependencies (generated by npm install — do not commit) ──────────────────
node_modules/
.pnp
.pnp.js

# ── Build artifacts ──────────────────────────────────────────────────────────
# dist/ is intentionally tracked — contains built extension files
build/
*.tgz

# ── Source maps ───────────────────────────────────────────────────────────────
*.map

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test / coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Chrome extension packaging ───────────────────────────────────────────────
*.crx
*.zip

# ── Temp / conflict files ────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*conflicted copy*
*.dropbox
