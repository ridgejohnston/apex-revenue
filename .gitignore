# Apex Revenue Chrome Extension — .gitignore

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/
*.tgz

# ── Source maps (large, not needed in repo) ──────────────────────────────────
*.map

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test / coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Chrome extension artifacts ───────────────────────────────────────────────
# Packed extension files
*.crx
*.pem

# ── Temp files ───────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
