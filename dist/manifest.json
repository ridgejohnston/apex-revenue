{
  "manifest_version": 3,
  "name": "Apex Revenue",
  "version": "0.6.0",
  "description": "Creator intelligence engine for cam performers. Real-time monetization prompts, whale tracking, fan leaderboards, and session replay analytics.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://chaturbate.com/*",
    "https://*.chaturbate.com/*",
    "https://stripchat.com/*",
    "https://*.stripchat.com/*",
    "https://myfreecams.com/*",
    "https://*.myfreecams.com/*",
    "https://xtease.com/*",
    "https://*.xtease.com/*",
    "https://api.emailjs.com/*",
    "https://us.i.posthog.com/*",
    "https://*.posthog.com/*",
    "https://us-assets.i.posthog.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.emailjs.com https://us.i.posthog.com https://us-assets.i.posthog.com https://*.posthog.com"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Apex Revenue",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chaturbate.com/*",
        "https://*.chaturbate.com/*",
        "https://stripchat.com/*",
        "https://*.stripchat.com/*",
        "https://myfreecams.com/*",
        "https://*.myfreecams.com/*",
        "https://xtease.com/*",
        "https://*.xtease.com/*"
      ],
      "js": [
        "content.js",
        "popout.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "overlay.html",
        "overlay.js",
        "overlay.css",
        "popup.css",
        "posthog.js",
        "posthog-init.js",
        "ph-recorder.js",
        "icons/*"
      ],
      "matches": [
        "https://chaturbate.com/*",
        "https://*.chaturbate.com/*",
        "https://stripchat.com/*",
        "https://*.stripchat.com/*",
        "https://myfreecams.com/*",
        "https://*.myfreecams.com/*",
        "https://xtease.com/*",
        "https://*.xtease.com/*"
      ]
    }
  ]
}