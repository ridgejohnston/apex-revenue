{
  "name": "apex-revenue",
  "version": "0.6.0",
  "description": "Creator intelligence engine for cam performers. Real-time monetization prompts, whale tracking, fan leaderboards, and multi-platform support.",
  "private": true,
  "scripts": {
    "build": "npx vite build && node -e \"const fs=require('fs');['manifest.json','overlay.js','overlay.html','overlay.css','apex-config.js','auth.js','content.js','recovery.html','recovery.js'].forEach(f=>fs.copyFileSync(f,'dist/'+f));fs.copyFileSync('node_modules/posthog-js/dist/array.full.no-external.js','dist/array.full.no-external.js');fs.copyFileSync('node_modules/posthog-js/dist/posthog-recorder.js','dist/posthog-recorder.js')\"",
    "watch": "npx vite build --watch"
  },
  "devDependencies": {
    "vite": "^5.4.21",
    "web-ext": "^7.11.0"
  },
  "dependencies": {
    "posthog-js": "^1.360.2"
  },
  "keywords": [
    "chrome-extension",
    "cam",
    "monetization",
    "chaturbate",
    "stripchat"
  ],
  "author": "Ridge Johnston",
  "license": "UNLICENSED"
}
